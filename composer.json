{
    "name": "adipradana/filament-turnstile",
    "description": "Cloudflare Turnstile integration for Laravel Filament login and forms.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "filament/filament": "^5.0",
        "laravel/framework": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "Adipradana\\FilamentTurnstile\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Adipradana\\FilamentTurnstile\\FilamentTurnstileServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
