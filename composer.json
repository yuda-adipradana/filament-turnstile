{
  "name": "adipradana/filament-turnstile",
  "description": "Cloudflare Turnstile integration for Laravel Filament login and forms.",
  "type": "library",
  "license": "MIT",
  "keywords": ["filament", "turnstile", "captcha", "cloudflare"],
  "homepage": "https://github.com/yuda-adipradana/filament-turnstile",
  "require": {
    "php": "^8.1 || ^8.2 || ^8.3",
    "filament/filament": "^3.0 || ^4.0 || ^5.0",
    "illuminate/support": "^10.0 || ^11.0 || ^12.0 || ^13.0"
  },
  "autoload": {
    "psr-4": {
      "Adipradana\\FilamentTurnstile\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Adipradana\\FilamentTurnstile\\FilamentTurnstileServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}